generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SecondHand {
  id        Int      @id @default(autoincrement())
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  logoUrl   String?  @map("logo_url")

  usuarios    Usuario[]
  proveedores Proveedor[]
  productos   Producto[]
  ventas      Venta[]
  ventaItems  VentaItem[]
  cajaSesiones CajaSesion[]
  cajaMovimientos CajaMovimiento[]
  menuPrecios MenuPrecio[]
  clientes Cliente[]
  cuentasCorrientes CuentaCorriente[]
  cuentaCorrienteMovimientos CuentaCorrienteMovimiento[]
  webVistaPrendas WebVistaPrenda[]

  @@map("second_hands")
}

model Usuario {
  id           Int     @id @default(autoincrement())
  idSecond     Int?    @map("id_second")
  email        String  @unique
  passwordHash String  @map("password_hash")
  nombre       String?
  rol          String

  secondHand SecondHand? @relation(fields: [idSecond], references: [id], onDelete: SetNull)

  @@map("usuarios")
}

model Proveedor {
  id        Int     @id @default(autoincrement())
  idSecond  Int     @map("id_second")
  nombre    String
  telefono  String?
  email     String?

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  productos  Producto[]

  @@index([idSecond])
  @@map("proveedores")
}

model Producto {
  id           Int     @id @default(autoincrement())
  idSecond     Int     @map("id_second")
  descripcion  String
  tipoPrenda   String? @map("tipo_prenda")
  marca        String?
  color        String?
  condicion    String?
  precioVenta  Float   @map("precio_venta")
  talle        String?
  idProveedor  Int     @map("id_proveedor")
  estado       String  @default("disponible")
  cantidad     Int?

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  proveedor  Proveedor  @relation(fields: [idProveedor], references: [id])
  ventaItems VentaItem[]

  @@index([idSecond])
  @@map("productos")
}

model CajaSesion {
  id        Int       @id @default(autoincrement())
  idSecond  Int       @map("id_second")
  abiertaEn DateTime  @default(now()) @map("abierta_en")
  cerradaEn DateTime? @map("cerrada_en")

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  ventas     Venta[]
  movimientos CajaMovimiento[]

  @@index([idSecond, cerradaEn])
  @@map("caja_sesiones")
}

model CajaMovimiento {
  id        Int      @id @default(autoincrement())
  idSecond  Int      @map("id_second")
  idCaja    Int      @map("id_caja")
  tipo      String
  monto     Float
  concepto  String?
  fecha     DateTime @default(now())

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  caja       CajaSesion @relation(fields: [idCaja], references: [id], onDelete: Cascade)

  @@index([idSecond])
  @@index([idCaja])
  @@index([idSecond, fecha])
  @@map("caja_movimientos")
}

model Venta {
  id        Int      @id @default(autoincrement())
  idSecond  Int      @map("id_second")
  idCaja    Int?     @map("id_caja")
  idCliente Int?     @map("id_cliente")
  fecha     DateTime @default(now())
  total     Float
  medioPago String?  @map("medio_pago")

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  caja       CajaSesion? @relation(fields: [idCaja], references: [id], onDelete: SetNull)
  cliente    Cliente? @relation(fields: [idCliente], references: [id], onDelete: SetNull)
  items      VentaItem[]
  cuentaCorrienteMovimiento CuentaCorrienteMovimiento?

  @@index([idSecond])
  @@index([idCaja])
  @@index([idCliente])
  @@map("ventas")
}

model VentaItem {
  id             Int   @id @default(autoincrement())
  idSecond       Int   @map("id_second")
  idVenta        Int   @map("id_venta")
  idProducto     Int   @map("id_producto")
  precioUnitario Float @map("precio_unitario")

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  venta      Venta      @relation(fields: [idVenta], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [idProducto], references: [id])

  @@index([idSecond])
  @@map("venta_items")
}

model MenuPrecio {
  id       Int    @id @default(autoincrement())
  idSecond Int    @map("id_second")
  nombre   String
  precio   Float

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)

  @@index([idSecond])
  @@map("menu_precios")
}

model Cliente {
  id              Int    @id @default(autoincrement())
  idSecond        Int    @map("id_second")
  nombre          String
  tipoDocumento   String @map("tipo_documento")
  numeroDocumento String @map("numero_documento")

  secondHand      SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  cuentaCorriente CuentaCorriente?
  ventas          Venta[]

  @@unique([idSecond, tipoDocumento, numeroDocumento])
  @@index([idSecond])
  @@map("clientes")
}

model CuentaCorriente {
  id        Int   @id @default(autoincrement())
  idSecond  Int   @map("id_second")
  idCliente Int   @unique @map("id_cliente")
  limite    Float
  saldo     Float @default(0)

  secondHand  SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  cliente     Cliente @relation(fields: [idCliente], references: [id], onDelete: Cascade)
  movimientos CuentaCorrienteMovimiento[]

  @@index([idSecond])
  @@map("cuentas_corrientes")
}

model CuentaCorrienteMovimiento {
  id       Int      @id @default(autoincrement())
  idSecond Int      @map("id_second")
  idCuenta Int      @map("id_cuenta")
  tipo     String
  monto    Float
  concepto String?
  idVenta  Int?     @unique @map("id_venta")
  fecha    DateTime @default(now())

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)
  cuenta     CuentaCorriente @relation(fields: [idCuenta], references: [id], onDelete: Cascade)
  venta      Venta? @relation(fields: [idVenta], references: [id], onDelete: SetNull)

  @@index([idSecond])
  @@index([idCuenta])
  @@index([idSecond, fecha])
  @@map("cuenta_corriente_movimientos")
}

/// Hasta 5 prendas de vitrina para landing web (independientes del inventario).
model WebVistaPrenda {
  id          Int      @id @default(autoincrement())
  idSecond    Int      @map("id_second")
  orden       Int
  nombre      String
  precio      Float
  descripcion String?
  imagen      String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  secondHand SecondHand @relation(fields: [idSecond], references: [id], onDelete: Cascade)

  @@unique([idSecond, orden])
  @@index([idSecond])
  @@map("web_vista_prendas")
}