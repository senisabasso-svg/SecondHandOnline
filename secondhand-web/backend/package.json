{
  "name": "secondhand-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npx prisma db push --accept-data-loss && node src/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "import:export-sqlite": "python ./scripts/export_sqlite_to_json.py",
    "import:from-json": "node ./scripts/import_from_json.js",
    "db:wipe-core": "node ./scripts/wipe_core_tables.js",
    "db:reset-seq": "node ./scripts/reset_sequences.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18"
  }
}